    "model_names = [\n",
    "    \"srk\",\n",
    "    \"pr\",\n",
    "    \"EOS-CG\",\n",
    "]\n",
    "pressure_grid_bara = np.linspace(1.0, 120.0, 16)\n",
    "\n",
    "property_rows = []\n",
    "for model_name in model_names:\n",
    "    for pressure_bara in pressure_grid_bara:\n",
    "        property_rows.append(\n",
    "            pure_co2_properties(\n",
    "                model_name,\n",
    "                temperature_c=40.0,\n",
    "                pressure_bara=float(pressure_bara),\n",
    "            )\n",
    "        )\n",
    "\n",
    "property_table = pd.DataFrame(property_rows)\n",
    "focused_reference_table = pd.DataFrame(\n",
    "    [\n",
    "        pure_co2_properties(\n",
    "            model_name,\n",
    "            temperature_c=40.0,\n",
    "            pressure_bara=80.0,\n",
    "        )\n",
    "        for model_name in [\n",
    "            \"srk\",\n",
    "            \"pr\",\n",
    "            \"span-wagner\",\n",
    "            \"EOS-CG\",\n",
    "        ]\n",
    "    ]\n",
    ")\n",
    "\n",
    "print(\"Focused four-model comparison at 40 °C and 80 bara\")\n",
    "display(focused_reference_table)\n",
    "print(\"Pressure-sweep endpoints\")\n",
    "display(\n",
    "    property_table[\n",
    "        property_table[\"Pressure [bara]\"].isin(\n",
    "            [1.0, 120.0]\n",
    "        )\n",
    "    ].reset_index(drop=True)\n",
    ")"
