   "source": [
    "benchmark_temperature_c = 320.0 - 273.15\n",
    "benchmark_pressure_bara = 2.0\n",
    "benchmark_density = 3.3079\n",
    "\n",
    "benchmark_system = create_pure_co2(\n",
    "    \"EOS-CG\",\n",
    "    benchmark_temperature_c,\n",
    "    benchmark_pressure_bara,\n",
    ")\n",
    "calculated_benchmark_density = benchmark_system.getDensity(\"kg/m3\")\n",
    "benchmark_relative_error = (\n",
    "    calculated_benchmark_density - benchmark_density\n",
    ") / benchmark_density\n",
    "\n",
    "gas_constant = 8.314462618\n",
    "co2_molar_mass = 0.0440095\n",
    "ideal_density = (\n",
    "    benchmark_pressure_bara\n",
    "    * 1.0e5\n",
    "    * co2_molar_mass\n",
    "    / (gas_constant * 320.0)\n",
    ")\n",
    "\n",
    "benchmark_table = pd.DataFrame(\n",
    "    {\n",
    "        \"Quantity\": [\n",
    "            \"Clapeyron reference\",\n",
    "            \"NeqSim EOS-CG\",\n",
    "            \"Ideal-gas limit\",\n",
    "        ],\n",
    "        \"Density [kg/m³]\": [\n",
    "            benchmark_density,\n",
    "            calculated_benchmark_density,\n",
    "            ideal_density,\n",
    "        ],\n",
    "    }\n",
    ")\n",
    "display(benchmark_table)\n",
    "print(f\"EOS-CG reference deviation: {benchmark_relative_error:.4%}\")\n",
    "\n",
    "assert abs(benchmark_relative_error) < 0.05\n",
    "assert abs(calculated_benchmark_density - ideal_density) / ideal_density < 0.03"
