   "id": "5e8cde49",
   "metadata": {},
   "source": [
    "## Preserved example: density at 25 °C and 30 bara\n",
    "\n",
    "The original SRK state and intended density calculation are unchanged. The result is\n",
    "recalculated with the current release and checked against a broad engineering range\n",
    "rather than copied from stale output."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "10074997",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "CO₂ density at 25 °C and 30 bara: 64.202212 kg/m³\n"
     ]
    }
   ],
   "source": [
    "base_srk = create_pure_co2(\n",
    "    \"srk\",\n",
    "    temperature_c=25.0,\n",
    "    pressure_bara=30.0,\n",
    ")\n",
    "base_density = base_srk.getDensity(\"kg/m3\")\n",
    "\n",
    "print(f\"CO₂ density at 25 °C and 30 bara: {base_density:.6f} kg/m³\")\n",
    "\n",
    "assert math.isfinite(base_density)\n",
    "assert 60.0 < base_density < 70.0"
   ]
