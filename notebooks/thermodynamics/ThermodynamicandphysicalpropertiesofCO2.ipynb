   "source": [
    "## Reusable pure-CO₂ property helper\n",
    "\n",
    "The helper creates a fresh thermodynamic system for every state. Fresh systems prevent\n",
    "hidden state from one model or pressure point from contaminating another calculation."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "e74b00b5",
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_pure_co2(model_name, temperature_c, pressure_bara):\n",
    "    if model_name == \"EOS-CG\":\n",
    "        system = SystemEOSCGEos(\n",
    "            temperature_c + 273.15,\n",
    "            pressure_bara,\n",
    "        )\n",
    "        system.addComponent(\"CO2\", 1.0)\n",
    "    elif model_name == \"span-wagner\":\n",
    "        system = SystemSpanWagnerEos(\n",
    "            temperature_c + 273.15,\n",
    "            pressure_bara,\n",
    "        )\n",
    "    else:\n",
    "        system = fluid(model_name)\n",
    "        system.setTemperature(temperature_c, \"C\")\n",
    "        system.setPressure(pressure_bara, \"bara\")\n",
    "        system.addComponent(\"CO2\", 1.0)\n",
    "    TPflash(system)\n",
    "    system.initProperties()\n",
    "    return system\n",
    "\n",
    "\n",
    "def pure_co2_properties(model_name, temperature_c, pressure_bara):\n",
    "    system = create_pure_co2(\n",
    "        model_name,\n",
    "        temperature_c,\n",
    "        pressure_bara,\n",
    "    )\n",
    "    phase = system.getPhase(0)\n",
    "    return {\n",
    "        \"Model\": model_name,\n",
    "        \"Temperature [°C]\": temperature_c,\n",
    "        \"Pressure [bara]\": pressure_bara,\n",
    "        \"Density [kg/m³]\": system.getDensity(\"kg/m3\"),\n",
    "        \"Z [-]\": phase.getZ(),\n",
    "        \"Cp [kJ/(kg·K)]\": phase.getCp(\"kJ/kgK\"),\n",
    "        \"Speed of sound [m/s]\": phase.getSoundSpeed(),\n",
    "        \"Viscosity [cP]\": system.getViscosity(\"cP\"),\n",
    "    }"
   ]
  },
  {
