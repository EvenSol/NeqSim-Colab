    "import numpy as np\n",
    "import pandas as pd\n",
    "from neqsim import jneqsim\n",
    "from neqsim.process import (\n",
    "    clearProcess,\n",
    "    compressor,\n",
    "    cooler,\n",
    "    distillationColumn,\n",
    "    expander,\n",
    "    getProcess,\n",
    "    heatExchanger,\n",
    "    heater,\n",
    "    mixer,\n",
    "    separator,\n",
    "    stream,\n",
    "    valve,\n",
    ")\n",
    "from neqsim.thermo import fluid_df\n",
    "\n",
    "\n",
    "plt.style.use(\"seaborn-v0_8-whitegrid\")\n",
    "pd.set_option(\"display.precision\", 7)\n",
    "\n",
    "ThermodynamicOperations = (\n",
